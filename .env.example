# ============================================================
# .env.example — copy to .env for local development
# In production, set these as GitHub Secrets and Vercel env vars
# ============================================================

# ── Vercel Blob (required by BOTH Vercel API and GitHub Actions pipeline)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxx

# ── Text AI — at least one required (Gemini preferred)
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Image AI — optional (SVG placeholders used if not set)
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Pipeline behaviour
FORCE_REFRESH=false   # Set to 'true' to re-process all items
